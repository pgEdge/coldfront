# Builds the ColdFront archiver (CGO-free static Go binary) for the walkthrough.
# Build context is the repo root (see compose). Lean: only the archiver module.
FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/archiver ./cmd/archiver
COPY internal ./internal
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /out/archiver ./cmd/archiver

FROM alpine:3.20
COPY --from=build /out/archiver /usr/local/bin/archiver
ENTRYPOINT ["/usr/local/bin/archiver"]
