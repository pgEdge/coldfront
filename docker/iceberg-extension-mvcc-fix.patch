+		DoTableUpdates(context);
+		DoTableDeletes(context);
 	} catch (std::exception &ex) {
 		ErrorData error(ex);
 		CleanupFiles();
-		DropSecrets(*context);
-		temp_con.Rollback();
+		DropSecrets(context);
 		error.Throw("Failed to commit Iceberg transaction: ");
 	}
-
-	temp_con.Rollback();
 }
 
