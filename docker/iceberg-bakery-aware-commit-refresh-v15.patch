# iceberg-bakery-aware-commit-refresh-v15.patch
#
# Applies to: duckdb-iceberg @ 5edc45f0 (branch v1.5-variegata), DuckDB v1.5.x.
#
# The bakery-aware commit-refresh patch for duckdb-iceberg v1.5-variegata. Full
# rationale: DUCKDB_1.5_PATCHED.md.
#
# The problem: coldfront uploads parquet OUTSIDE the R-A bakery and
# takes the ticket only for the commit POST, so a writer committing against
# session-cached metadata fails assert-ref-snapshot-id (Lakekeeper 409) when a
# peer advanced the head, and an append built from the stale cached manifest
# list silently drops the peer's data.
#
# v1.5 derives the new snapshot's parent + sequence_number at COMMIT time from
# table_metadata, so the fix is:
# inside IcebergTransaction::DoTableUpdates (PG PRE_COMMIT, holding the ticket),
# BEFORE GetTransactionRequest builds the commit, refresh each altered table's
# table_metadata from Lakekeeper (IRCAPI::GetTable) AND re-read its source
# manifest list, so both the asserted parent and the new manifest list reflect
# the fresh head. v1.5's existing commit-time derivation does the rest.
#
# CRITICAL (the part that differs from a naive port, and why mixed-tier
# concurrency was throwing "TransactionContext::ActiveTransaction called without
# active transaction"): the manifest-list re-read is a read_avro table-function
# SCAN, which needs a ClientContext with an ACTIVE transaction. It must run on
# the fresh temp_con that IcebergTransaction::Commit opens (temp_con.BeginTransaction()),
# NOT on IcebergTransactionData's stored context — that is the ORIGINAL/main
# connection, which during the commit xact callback has no active transaction
# (it is mid-commit). So CacheExistingManifestList / RefreshExistingManifestList
# take an explicit scan_context: AddSnapshot/AddUpdateSnapshot pass the member
# context (active during the INSERT); the commit-time refresh passes the
# temp_con context (DoTableUpdates' `context`). Pure-cold (9b) happened to
# survive the wrong context; the dual-CTE mixed-tier path (6b) did not.
#
# Verified: builds; ci/journey.sh 6b (4 concurrent mixed-tier writers) and 9b
# (8 concurrent cold writers) over Azure ADLS land 8/8 and 8/8 with 0 errors,
# 0 loss.
#
# The refresh block re-creates the table's vended storage secret in the
# commit context (PrepareIcebergScanFromEntry) before re-reading the manifest
# list: the commit runs on a fresh connection with no secret, and under
# catalog credential vending there is no persistent secret to fall back on.
#
diff --git a/src/catalog/rest/transaction/iceberg_transaction.cpp b/src/catalog/rest/transaction/iceberg_transaction.cpp
index 6901b08e..b057c3d8 100644
--- a/src/catalog/rest/transaction/iceberg_transaction.cpp
+++ b/src/catalog/rest/transaction/iceberg_transaction.cpp
@@ -7,6 +7,7 @@
 #include "duckdb/storage/table/update_state.hpp"
 #include "duckdb/parser/parsed_data/drop_info.hpp"
 #include "duckdb/main/client_data.hpp"
+#include "duckdb/common/exception/http_exception.hpp"
 #include "yyjson.hpp"
 
 #include "planning/metadata_io/manifest/iceberg_manifest_reader.hpp"
@@ -444,6 +445,82 @@ void IcebergTransaction::DoTableUpdates(IcebergTransactionAlterUpdate &alter_upd
 	if (!alter_update.HasUpdates()) {
 		return;
 	}
+
+	// ColdFront bakery-aware commit refresh.
+	//
+	// coldfront._exec_iceberg_with_claim uploads parquet OUTSIDE the R-A
+	// bakery and only acquires the ticket for this commit POST, which runs
+	// here at PG PRE_COMMIT. Every field of the new snapshot is derived at
+	// commit time from table_info.table_metadata: GetTransactionRequest reads
+	// the parent via GetLatestSnapshot() and emits the assert-ref-snapshot-id
+	// requirement from it, and IcebergCommitState seeds next_sequence_number
+	// from last_sequence_number. But that metadata was loaded from Lakekeeper
+	// BEFORE the bakery -- an earlier ticket-holder may have committed since,
+	// so the cached head is stale and the assert-ref precondition would 409.
+	//
+	// We hold the ticket now, so no other coldfront writer can move the head
+	// until we release. Re-read each altered table's metadata from Lakekeeper
+	// exactly once, here, before GetTransactionRequest builds the commit
+	// state. Everything downstream then derives from the fresh head: the
+	// asserted parent snapshot-id matches the catalog, parent_snapshot_id and
+	// the snapshot/manifest sequence_number are re-derived correctly (the
+	// temp sequence_number baked into the manifest file at AddSnapshot time is
+	// overwritten on commit by AddNewManifestFile, and ADDED entries inherit
+	// it), and the new manifest list is built on top of the peer's manifests
+	// instead of silently dropping them.
+	for (auto &updated_table : alter_update.updated_tables) {
+		if (alter_update.committed_tables.count(updated_table.first)) {
+			continue;
+		}
+		auto &table_info = updated_table.second;
+		if (!table_info.transaction_data) {
+			continue;
+		}
+		auto &transaction_data = *table_info.transaction_data;
+		// Nothing to refresh for a table without staged data (e.g. pure DDL):
+		// the assert-ref precondition only applies when we add a snapshot.
+		if (transaction_data.alters.empty()) {
+			continue;
+		}
+		// Tables CREATEd in this same transaction (carrying an ASSERT_CREATE
+		// requirement) do not exist in the catalog yet, so GetTable would 404.
+		// Their cached metadata is the authoritative initial state -- leave it.
+		bool is_being_created = false;
+		for (auto &requirement : transaction_data.requirements) {
+			if (requirement->type == IcebergTableRequirementType::ASSERT_CREATE) {
+				is_being_created = true;
+				break;
+			}
+		}
+		if (is_being_created) {
+			continue;
+		}
+		auto &schema = table_info.schema.Cast<IcebergSchemaEntry>();
+		auto refreshed = IRCAPI::GetTable(context, catalog, schema, table_info.name);
+		if (refreshed.has_error) {
+			throw HTTPException(
+			    StringUtil::Format("iceberg: pre-commit metadata refresh returned response code %s with message \"%s\"",
+			                       EnumUtil::ToString(refreshed.status_), refreshed.error_._error.message));
+		}
+		// initialize_schemas=false: schema versions are already populated and
+		// the cold-append path does not change the schema; this mirrors the
+		// cached-reinit path (iceberg_table_set.cpp / CreateMetadataFromLog).
+		table_info.InitializeFromLoadTableResult(*refreshed.result_, false);
+		// Vended credentials: (re)create this table's storage secret in THIS
+		// context before the manifest-list re-read below touches object
+		// storage. This commit runs on a fresh connection whose context has no
+		// secret yet (the one from planning is not visible here), so without
+		// this the re-read has no credential. Same idiom as
+		// GetTransactionRequest's ADD_SNAPSHOT loop ("we need to recreate the
+		// keys in the current context"); with access-delegation NONE (static
+		// credentials via a persistent secret) it returns immediately.
+		auto &ic_table_entry = table_info.GetLatestSchema(context)->Cast<IcebergTableEntry>();
+		ic_table_entry.PrepareIcebergScanFromEntry(context);
+		// Re-read the source manifest list from the freshly-loaded head so the
+		// new manifest list is built on top of the peer's manifests.
+		transaction_data.RefreshExistingManifestList(context);
+	}
+
 	auto transaction_info = GetTransactionRequest(alter_update, context);
 	auto &transaction = transaction_info.request;
 
