@@ -41,7 +47,7 @@ void IcebergTransactionData::CacheExistingManifestList(lock_guard<mutex> &guard,
 	auto &manifest_list_path = current_snapshot->manifest_list;
 	//! Read the manifest list
 	auto scan =
-	    AvroScan::ScanManifestList(snapshot_info, metadata, context, manifest_list_path, existing_manifest_list);
+	    AvroScan::ScanManifestList(snapshot_info, metadata, scan_context, manifest_list_path, existing_manifest_list);
 	auto manifest_list_reader = make_uniq<manifest_list::ManifestListReader>(*scan);
 	while (!manifest_list_reader->Finished()) {
 		manifest_list_reader->Read();
@@ -71,6 +77,22 @@ void IcebergTransactionData::CacheExistingManifestList(lock_guard<mutex> &guard,
 	}
 }
 
+void IcebergTransactionData::RefreshExistingManifestList(ClientContext &scan_context) {
+	//! ColdFront bakery-aware refresh of the cached source manifest list.
+	//!
+	//! ColdFront uploads parquet OUTSIDE the R-A bakery and only takes the
+	//! ticket for the commit POST. The existing_manifest_list was scanned at
+	//! AddSnapshot time from the snapshot that was current then; an earlier
+	//! ticket-holder may have committed since, adding manifest files we have
+	//! not seen. If we built the new manifest list from the stale cache we
+	//! would silently drop the peer's data. We hold the ticket now, so the
+	//! refreshed table_metadata head is the value our commit will assert
+	//! against; re-read the manifest list from it. force=true is required
+	//! because 'alters' is already populated by this point.
+	lock_guard<mutex> guard(lock);
+	CacheExistingManifestList(guard, table_info.table_metadata, scan_context, true);
+}
