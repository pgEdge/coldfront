# iceberg-manifest-content-v15.patch
#
# Applies to: duckdb-iceberg @ 0fad545a (branch v1.5-variegata), DuckDB v1.5.x.
#
# Cross-engine interop fix — upstreamable to duckdb-iceberg. Companion
# to iceberg-manifest-list-format-version-v15.patch; same class of bug.
#
# Problem: the manifest FILE Avro writer (manifest::WriteToFile) hardcodes the
# "content" metadata key to "data" for EVERY manifest, including DELETE manifests
# (positional/equality deletes that the cold tier produces on UPDATE/DELETE). The
# manifest LIST entry, by contrast, records the manifest's real content
# (data/deletes). Strict Apache readers (iceberg-go, PyIceberg, Spark) cross-check
# the two and reject the table:
#   "manifest file's 'content' metadata indicates \"data\", but entry from
#    manifest list indicates \"deletes\""  (iceberg-go manifest.go:651).
# This is the SECOND interop blocker the compactor hit, exposed once the
# format-version patch let iceberg-go parse the manifests as v2 and reach the
# content check.
#
# Fix: derive the "content" key from manifest_file.content (DATA -> "data",
# DELETE -> "deletes"), the same source the manifest list entry uses, so the two
# always agree. IcebergManifestFile + IcebergManifestContentType are both defined
# in core/metadata/manifest/iceberg_manifest_list.hpp (transitively included), so
# no new include is needed.
#
# SAFE — does not change anything that works today: duckdb-iceberg's own manifest
# reader derives content from the manifest list entry, not from this Avro key, so
# emitting the correct value is inert to pg_duckdb reads and only enables
# cross-engine readers.
#
diff --git a/src/core/metadata/manifest/iceberg_manifest.cpp b/src/core/metadata/manifest/iceberg_manifest.cpp
index b8fdaee3..8b9ac481 100644
--- a/src/core/metadata/manifest/iceberg_manifest.cpp
+++ b/src/core/metadata/manifest/iceberg_manifest.cpp
@@ -647,7 +647,14 @@ idx_t WriteToFile(const IcebergTableMetadata &table_metadata, const IcebergManif
 	metadata_values.emplace_back("partition-spec", current_partition_spec.FieldsToJSONString());
 	metadata_values.emplace_back("partition-spec-id", std::to_string(current_partition_spec.spec_id));
 	metadata_values.emplace_back("format-version", std::to_string(table_metadata.iceberg_version));
-	metadata_values.emplace_back("content", "data");
+	//! "data" or "deletes" per the manifest's ACTUAL content type — not hardcoded.
+	//! Strict Apache readers (iceberg-go, PyIceberg, Spark) cross-check this Avro
+	//! metadata key against the manifest list entry's content and reject a delete
+	//! manifest mis-tagged as data. duckdb-iceberg's own reader ignores the key
+	//! (it derives content from the manifest list entry), so this is inert to our
+	//! read path and only fixes cross-engine interop.
+	metadata_values.emplace_back(
+	    "content", manifest_file.content == IcebergManifestContentType::DATA ? "data" : "deletes");
 	auto metadata_map = Value::STRUCT(std::move(metadata_values));

 	CopyInfo copy_info;
