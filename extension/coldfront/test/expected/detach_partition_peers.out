-- coldfront._detach_partition_peers(parent, partition) re-runs DETACH PARTITION
-- … CONCURRENTLY on every OTHER spock mesh node. Spock's DDL replication cannot
-- carry the concurrent detach itself (it is non-transactional), so the partition
-- manager (internal/partition Manager.Detach) calls this after every local
-- detach. White-box: OFF-mesh (spock not installed) it must be a clean no-op
-- returning 0 — a vanilla node has no peers and must never error. The real
-- 3-node fan-out is exercised live in ci/journey.sh (story_mesh_partition_ddl).
CREATE EXTENSION IF NOT EXISTS pg_duckdb;
NOTICE:  extension "pg_duckdb" already exists, skipping
CREATE EXTENSION IF NOT EXISTS coldfront;
NOTICE:  extension "coldfront" already exists, skipping
-- Defined with the expected (parent, partition) text signature.
SELECT pg_get_function_arguments('coldfront._detach_partition_peers'::regproc);
    pg_get_function_arguments    
---------------------------------
 p_parent text, p_partition text
(1 row)

-- Off-mesh: the spock guard short-circuits to 0 before touching the arguments,
-- so a non-existent table name is irrelevant and nothing is detached.
SELECT coldfront._detach_partition_peers('public.nope', 'public.nope_p0');
 _detach_partition_peers 
-------------------------
                       0
(1 row)

